<Page x:Class="MebelShop.Customer.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Каталог">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FilterColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Filter Sidebar -->
        <Border Grid.Column="0" Width="260" VerticalAlignment="Stretch"
                Background="{DynamicResource MaterialDesignPaper}" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="8" ShadowDepth="2" Direction="180"/>
            </Border.Effect>

            <StackPanel x:Name="FiltersPanel" Margin="20,20,20,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Фильтры" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,0,0,16"/>

                <TextBlock Text="Категория" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,6"/>
                <ComboBox x:Name="CategoryComboBox"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Все категории"
                          SelectionChanged="CategoryComboBox_SelectionChanged"
                          Margin="0,0,0,16"/>

                <StackPanel x:Name="CharacteristicsPanel" Margin="0,0,0,16"/>

                <Button Content="✓  Применить"
                        Height="40" Margin="0,8,0,6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="ApplyFilters_Click"/>
                <Button Content="✕  Сбросить"
                        Height="40"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="ResetFilters_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search & sort bar -->
            <Border Grid.Row="0" Background="{DynamicResource MaterialDesignPaper}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MaxWidth="400"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ToggleFilterButton"
                            Grid.Column="0"
                            Content="☰  Фильтры"
                            Width="120" Height="36"
                            Margin="0,0,12,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="ToggleFilterButton_Click"/>

                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="🔍  Поиск по товарам"
                             Margin="0,0,12,0"
                             TextChanged="SearchTextBox_TextChanged"/>

                    <Button Content="Найти"
                            Grid.Column="2"
                            Width="90" Height="36"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Margin="0,0,12,0"
                            Click="SearchButton_Click"/>

                    <ComboBox x:Name="SortComboBox"
                              Grid.Column="3"
                              Width="210"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Сортировка"
                              SelectionChanged="SortComboBox_SelectionChanged"
                              SelectedIndex="0">
                        <ComboBoxItem Content="По умолчанию"/>
                        <ComboBoxItem Content="Сначала дешёвые"/>
                        <ComboBoxItem Content="Сначала дорогие"/>
                        <ComboBoxItem Content="Высокий рейтинг"/>
                        <ComboBoxItem Content="Сначала популярные"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Products grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
                <ItemsControl x:Name="ProductsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Product card -->
                            <Border Width="210" Margin="10"
                                    CornerRadius="12"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Card_MouseLeftButtonUp">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.10" BlurRadius="14" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#000" Opacity="0.18" BlurRadius="20" ShadowDepth="4" Direction="270"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="170"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Product image -->
                                    <Border Grid.Row="0" CornerRadius="12,12,0,0" ClipToBounds="True" Background="#F5F5F5">
                                        <Image Source="{Binding MainImageUrl}" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"/>
                                    </Border>

                                    <!-- Product info -->
                                    <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                        <TextBlock Text="{Binding ProductName}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   TextWrapping="Wrap" MaxHeight="40"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,6"/>

                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                                   FontSize="17" FontWeight="Bold"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                   Margin="0,0,0,4"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="★" Foreground="#FFC107" FontSize="13"/>
                                            <TextBlock Text="{Binding AverageRating, StringFormat=' {0:F1}'}"
                                                       FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReviewsCount, StringFormat=' ({0})'}"
                                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Content="{Binding CartButtonText}"
                                                Height="34"
                                                FontSize="12"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Margin="0,6,0,0"
                                                Click="CartButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Load more -->
            <Border Grid.Row="2" Padding="0,10,0,16" HorizontalAlignment="Center">
                <Button x:Name="LoadMoreButton"
                        Content="Загрузить ещё"
                        Height="40" Padding="32,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="20"
                        Click="LoadMoreButton_Click"/>
            </Border>
        </Grid>
    </Grid>
</Page>
