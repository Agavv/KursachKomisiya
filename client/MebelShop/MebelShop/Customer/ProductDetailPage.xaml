<Page x:Class="MebelShop.Customer.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Детали товара">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Breadcrumb -->
        <Border Grid.Row="0" Padding="24,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Button Content="← Назад в каталог"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                    FontSize="13" HorizontalAlignment="Left"
                    Click="BackButton_Click"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="440" MaxWidth="480"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Images column ===== -->
                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                        CornerRadius="12" ClipToBounds="True"
                        Background="{DynamicResource MaterialDesignCardBackground}" Margin="0,0,24,0"
                        Height="440" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ImagesListBox" ItemsSource="{Binding ImageUrls}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Image Stretch="UniformToFill" Source="{Binding}"
                                           Width="440" Height="440"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True"
                                           MouseLeftButtonUp="Image_MouseLeftButtonUp"
                                           Cursor="Hand"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ===== Product info ===== -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,20">
                    <TextBlock x:Name="ProductNameText"
                               FontSize="26" FontWeight="Bold"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- FIX: Code-behind sets AverageRatingText.Text = "⭐ 4.5"
                         so no static star prefix here to avoid "★ ⭐ 4.5" double -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock x:Name="AverageRatingText"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#FFC107"/>
                        <TextBlock Text="  |  " FontSize="14"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ReviewsCountText"
                                   FontSize="14"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="PriceText"
                               FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryHueMidBrush}"
                               Margin="0,0,0,20"/>

                    <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,0,0,16"/>

                    <TextBlock Text="Описание" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="DescriptionText"
                               TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                </StackPanel>

                <!-- ===== Characteristics ===== -->
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="10"
                        Background="{DynamicResource MaterialDesignPaper}"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Характеристики" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="CharacteristicsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ===== Reviews section ===== -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Отзывы покупателей"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <!-- Add review panel -->
                        <StackPanel x:Name="AddReviewPanel" Visibility="Collapsed" Margin="0,0,0,16">
                            <Border CornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Ваш отзыв" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                                    <TextBox x:Name="ReviewTextBox"
                                             Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Поделитесь впечатлением о товаре..."
                                             Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Оценка:" FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Slider x:Name="RatingSlider" Minimum="1" Maximum="5" Value="5"
                                                Width="160" TickFrequency="1" IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ElementName=RatingSlider, Path=Value}"
                                                   FontWeight="Bold" FontSize="16"
                                                   Foreground="#FFC107" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="Отправить отзыв"
                                            Height="36" Width="160" HorizontalAlignment="Left"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="SubmitReview_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Sort panel -->
                        <StackPanel x:Name="ReviewSortPanel" Orientation="Horizontal"
                                    Margin="0,0,0,14" Visibility="Collapsed">
                            <TextBlock Text="Сортировать:" FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="ReviewSortComboBox" Width="200" SelectedIndex="0"
                                      SelectionChanged="ReviewSortComboBox_SelectionChanged">
                                <ComboBoxItem Content="По умолчанию"/>
                                <ComboBoxItem Content="Высокий рейтинг"/>
                                <ComboBoxItem Content="Низкий рейтинг"/>
                                <ComboBoxItem Content="Самые новые"/>
                                <ComboBoxItem Content="Самые старые"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Reviews list -->
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReviewsItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                Padding="8,14,8,14" Margin="0,2">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Header: name + date -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding UserName}"
                                                               FontWeight="SemiBold" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}"
                                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                               FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Rating -->
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Rating, StringFormat='★ {0}/5'}"
                                                           Foreground="#FFC107" FontSize="13"
                                                           Margin="0,6,0,6"/>

                                                <!-- Comment -->
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Comment}"
                                                           TextWrapping="Wrap" FontSize="13"
                                                           LineHeight="20"/>

                                                <!-- Delete button (own reviews only) -->
                                                <Button Grid.Column="1" Grid.RowSpan="3"
                                                        Content="Удалить"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Foreground="#EF5350" FontSize="12"
                                                        Visibility="{Binding IsMine, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Click="DeleteReview_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
