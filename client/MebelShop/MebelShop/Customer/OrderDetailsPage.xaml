<Page x:Class="MebelShop.Customer.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: order items -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock x:Name="OrderHeaderTextBlock"
                           Text="Детали заказа"
                           FontSize="24" FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <ItemsControl x:Name="OrderItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Margin="0,0,0,10"
                                    Background="{DynamicResource MaterialDesignPaper}"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Border_MouseLeftButtonUp">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Grid Margin="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" ClipToBounds="True" Background="#F5F5F5" Width="60" Height="60">
                                        <Image Source="{Binding MainImageUrl}" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding ProductName}"
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               FontSize="14" Margin="12,0" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                               FontSize="13"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                               Text="{Binding Quantity, StringFormat='×{0}'}"
                                               FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextAlignment="Center" FontWeight="SemiBold" Margin="6,0"/>
                                    <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                               Text="{Binding TotalPrice, StringFormat='{}{0:N0} ₽'}"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource SecondaryHueMidBrush}">
                                        <TextBlock.ToolTip>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Цена за шт.: ₽{0:N2} — Кол-во: {1}">
                                                        <Binding Path="Price"/>
                                                        <Binding Path="Quantity"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Actions -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="← Назад"
                            Height="40" Padding="20,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="BackButton_Click"/>
                    <Button Grid.Column="2"
                            Content="🔄  Повторить заказ"
                            Height="40" Padding="20,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="RepeatOrder_Click"/>
                </Grid>
            </StackPanel>

            <!-- Right: summary card -->
            <Border Grid.Column="1" CornerRadius="12"
                    Background="{DynamicResource MaterialDesignPaper}"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.10" BlurRadius="14" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <StackPanel Margin="20">
                    <TextBlock Text="Сводка заказа" FontSize="16" FontWeight="Bold" Margin="0,0,0,14"/>
                    <Border Height="1" Background="#ECEFF1" Margin="0,0,0,14"/>
                    <TextBlock x:Name="TotalPriceTextBlock"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
