<Page x:Class="MebelShop.Customer.CheckoutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Оформление заказа">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: form sections -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Оформление заказа" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

                <!-- Buyer info section -->
                <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Данные покупателя" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FirstNameTextBox" Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Имя"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     TextChanged="FirstNameTextBox_TextChanged"/>
                            <TextBox x:Name="LastNameTextBox" Grid.Column="2"
                                     materialDesign:HintAssist.Hint="Фамилия"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     TextChanged="LastNameTextBox_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Items section -->
                <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Ваши товары" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ItemsControl x:Name="OrderItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,4"
                                            CornerRadius="8" Background="#F8F9FA">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="6" ClipToBounds="True" Background="#E0E0E0">
                                                <Image Grid.Column="0" Source="{Binding MainImageUrl}"
                                                       Width="56" Height="56" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       SnapsToDevicePixels="True"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding ProductName}"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       FontSize="13" TextTrimming="CharacterEllipsis"
                                                       Margin="10,0"/>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                                       FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                       Text="{Binding Quantity, StringFormat='×{0}'}"
                                                       FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       TextAlignment="Center" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                                       Text="{Binding TotalPrice, StringFormat='{}{0:N0} ₽'}"
                                                       HorizontalAlignment="Right" FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SecondaryHueMidBrush}">
                                                <TextBlock.ToolTip>
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="Цена за шт.: ₽{0:N2} — Кол-во: {1}">
                                                                <Binding Path="Price"/>
                                                                <Binding Path="Quantity"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Delivery section -->
                <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="📍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Адрес доставки" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" Content="Самовывоз"
                                         GroupName="DeliveryOption" IsChecked="True"
                                         Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1" x:Name="PickupPointsComboBox"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,10,0" SelectedIndex="0"/>
                            <Button Grid.Column="2" Content="🗺 На карте"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Height="38"
                                    Click="ShowPickupOnMap_Click"/>
                        </Grid>
                        <Grid x:Name="DeliveryAddressPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Content="Доставка по адресу"
                                         GroupName="DeliveryOption" Margin="0,0,12,0"/>
                            <ComboBox x:Name="AddressComboBox"
                                      Grid.Column="1"
                                      IsEditable="True"
                                      StaysOpenOnEdit="True"
                                      IsTextSearchEnabled="False"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Введите адрес"
                                      SelectionChanged="AddressComboBox_SelectionChanged"
                                      TextBoxBase.TextChanged="AddressComboBox_TextChanged"
                                      PreviewMouseLeftButtonUp="AddressComboBox_PreviewMouseLeftButtonUp"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Payment section -->
                <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="💳" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Способ оплаты" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <RadioButton x:Name="CashOnDeliveryRadio"
                                     IsChecked="True"
                                     Content="Оплата при получении"
                                     GroupName="PaymentOption"
                                     Margin="0,0,0,8"
                                     Checked="PaymentOption_Checked"/>

                        <StackPanel x:Name="CashOnDeliveryOptions" Margin="20,0,0,10" Visibility="Visible">
                            <RadioButton Content="Наличными" GroupName="CashOnDeliveryMethod" IsChecked="True" Margin="0,0,0,4"/>
                            <RadioButton Content="Картой" GroupName="CashOnDeliveryMethod"/>
                        </StackPanel>

                        <RadioButton x:Name="OnlineRadio"
                                     Content="Онлайн-оплата картой"
                                     GroupName="PaymentOption"
                                     Margin="0,0,0,10"
                                     Checked="PaymentOption_Checked"/>

                        <Border x:Name="CardPaymentPanel" Visibility="Collapsed"
                                CornerRadius="8" Background="#F8F9FA" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.ColumnSpan="3" x:Name="CardNumberTextBox"
                                         materialDesign:HintAssist.Hint="Номер карты (0000 0000 0000 0000)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="CardNumberTextBox_TextChanged"
                                         MaxLength="19"/>
                                <TextBox Grid.Row="2" Grid.Column="0"
                                         x:Name="CardExpiryTextBox"
                                         materialDesign:HintAssist.Hint="ММ/ГГ"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="CardExpiryTextBox_TextChanged"
                                         MaxLength="5"/>
                                <TextBox Grid.Row="2" Grid.Column="2"
                                         x:Name="CardCvvTextBox"
                                         materialDesign:HintAssist.Hint="CVV"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="CardCvvTextBox_TextChanged"
                                         MaxLength="3"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: order summary -->
            <Border Grid.Column="1" CornerRadius="12"
                    Background="{DynamicResource MaterialDesignPaper}"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.10" BlurRadius="16" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <StackPanel Margin="22">
                    <TextBlock Text="Ваш заказ" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                    <Border Height="1" Background="#ECEFF1" Margin="0,0,0,14"/>
                    <TextBlock x:Name="TotalItemsTextBlock" FontSize="14"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TotalPriceTextBlock" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryHueMidBrush}" Margin="0,0,0,20"/>
                    <Button Content="✓  Подтвердить заказ"
                            Height="48" FontSize="15" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="SubmitOrder_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
