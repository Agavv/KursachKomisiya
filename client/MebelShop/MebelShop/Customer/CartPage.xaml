<Page x:Class="MebelShop.Customer.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Корзина">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CartItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Orange" BorderThickness="1" Margin="5" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="{Binding ImageUrl}" Width="100" Height="100" Grid.Column="0"
                                       Stretch="UniformToFill"
                                       Cursor="Hand" MouseLeftButtonUp="Product_Click"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"/>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="{Binding ProductName}" FontSize="16" FontWeight="Bold" Cursor="Hand" MouseLeftButtonUp="Product_Click"/>
                                    <TextBlock Text="{Binding Price, StringFormat='Цена: {0} ₽'}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="10,0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Content="-"
                                            Tag="{Binding ProductId}"
                                            Click="DecreaseQuantity_Click"/>
                                    <TextBlock Text="{Binding Quantity}" FontSize="16" Margin="10,0" VerticalAlignment="Center"/>
                                    <Button Content="+"
                                            Tag="{Binding ProductId}"
                                            Click="IncreaseQuantity_Click"/>
                                </StackPanel>

                                <Button Content="Удалить" Grid.Column="3"
                                        Tag="{Binding ProductId}"
                                        Click="RemoveItem_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="0,0,20,0">
                <TextBlock x:Name="TotalCountText" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock x:Name="TotalPriceText" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
            <Button Content="Перейти к оформлению" Width="200" Height="40" Click="Checkout_Click"/>
        </StackPanel>
    </Grid>
</Page>