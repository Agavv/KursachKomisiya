<Page x:Class="MebelShop.Customer.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Корзина">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Cart items -->
        <Grid Grid.Column="0" Margin="24,24,16,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🛒" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Корзина" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CartItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" CornerRadius="10"
                                    Background="{DynamicResource MaterialDesignPaper}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Grid Margin="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True"
                                            Background="#F5F5F5" Width="90" Height="90">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                               Cursor="Hand" MouseLeftButtonUp="Product_Click"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProductName}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Cursor="Hand" MouseLeftButtonUp="Product_Click"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽ за шт.'}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Quantity controls -->
                                    <Border Grid.Column="2" CornerRadius="20" Background="#F5F5F5"
                                            Margin="12,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <Button Content="Убавить" Width="30" Height="30"
                                                    Tag="{Binding ProductId}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    FontSize="16" FontWeight="Bold"
                                                    Click="DecreaseQuantity_Click"/>
                                            <TextBlock Text="{Binding Quantity}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Width="28" TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="Добавить" Width="30" Height="30"
                                                    Tag="{Binding ProductId}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    FontSize="16" FontWeight="Bold"
                                                    Click="IncreaseQuantity_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Grid.Column="3"
                                            Content="Удалить" Width="36" Height="36"
                                            Tag="{Binding ProductId}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                                            VerticalAlignment="Center"
                                            ToolTip="Удалить из корзины"
                                            Click="RemoveItem_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Order summary panel -->
        <Border Grid.Column="1" Margin="0,24,24,24" CornerRadius="12"
                Background="{DynamicResource MaterialDesignPaper}" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.10" BlurRadius="16" ShadowDepth="3" Direction="270"/>
            </Border.Effect>
            <StackPanel Margin="24">
                <TextBlock Text="Итого" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Количество товаров:"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="13"/>
                    <TextBlock x:Name="TotalCountText" Grid.Column="1"
                               FontSize="13" FontWeight="Medium"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Сумма заказа:" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalPriceText" Grid.Column="1"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                </Grid>

                <Button Content="Оформить заказ →"
                        Height="46" FontSize="14" FontWeight="SemiBold"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="Checkout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
