<Page x:Class="MebelShop.Customer.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Профиль">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="👤" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="Мой профиль" FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl Grid.Row="1" materialDesign:ColorZoneAssist.Mode="PrimaryLight">

            <!-- ====== Мои заказы ====== -->
            <TabItem Header="📋  Мои заказы">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <ItemsControl x:Name="OrdersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,12"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="Border_MouseLeftButtonUp">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                                    </Border.Effect>
                                    <Grid Margin="18,14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Order header -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding OrderId, StringFormat='Заказ №{0}'}"
                                                       FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       FontSize="13" VerticalAlignment="Center" Margin="12,0"/>
                                            <Border Grid.Column="2" CornerRadius="12" Padding="10,4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#FFF8E1"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#E65100"
                                                           FontWeight="SemiBold" FontSize="12"/>
                                            </Border>
                                        </Grid>

                                        <!-- Product images strip -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductImages}" Margin="0,10,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="56" Height="56" CornerRadius="8"
                                                            ClipToBounds="True" Margin="0,0,8,0" Background="#F5F5F5">
                                                        <Image Source="{Binding}" Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Total -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding TotalPrice, StringFormat='Итого: {0:N0} ₽'}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                   Margin="0,10,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Мои товары ====== -->
            <TabItem Header="🛍  Мои товары">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <ItemsControl x:Name="MyProductsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,10"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="BorderProduct_MouseLeftButtonUp">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                    </Border.Effect>
                                    <Grid Margin="14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border CornerRadius="8" ClipToBounds="True" Background="#F5F5F5"
                                                Width="64" Height="64">
                                            <Image Source="{Binding MainImageUrl}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   FontSize="14" Margin="14,0"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                                   VerticalAlignment="Center"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                   Margin="0,0,14,0"/>
                                        <Button Grid.Column="3"
                                                Content="{Binding CartButtonText}"
                                                Height="36"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Click="CartButton_Click"
                                                DataContext="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Мои отзывы ====== -->
            <TabItem Header="⭐  Мои отзывы">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <ItemsControl x:Name="MyReviewsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,10"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="BorderReviews_MouseLeftButtonUp">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                    </Border.Effect>
                                    <Grid Margin="14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border CornerRadius="8" ClipToBounds="True" Background="#F5F5F5"
                                                Width="64" Height="64">
                                            <Image Source="{Binding ProductImageUrl}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProductName}"
                                                       FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Comment}"
                                                       TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       Margin="0,0,0,6" MaxWidth="600"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Rating, StringFormat='★ {0}/5'}"
                                                           Foreground="#FFC107" FontWeight="SemiBold" FontSize="13"
                                                           Margin="0,0,14,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Настройки профиля ====== -->
            <TabItem Header="⚙  Настройки">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,24,0,0">
                    <StackPanel Width="460" HorizontalAlignment="Left">

                        <!-- Personal info card -->
                        <Border CornerRadius="10" Margin="0,0,0,16"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel Margin="24">
                                <TextBlock Text="Личные данные" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <TextBlock Text="Имя" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                <TextBox x:Name="FirstNameTextBox"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="FirstNameTextBox_TextChanged"
                                         Margin="0,0,0,14"/>

                                <TextBlock Text="Фамилия" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                <TextBox x:Name="LastNameTextBox"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="LastNameTextBox_TextChanged"
                                         Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SaveProfileButton"
                                            Content="Сохранить изменения"
                                            IsEnabled="False"
                                            Height="38"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="SaveProfileButton_Click"/>
                                    <Button
                                            Height="38" Margin="10,0,0,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="Logout_ButtonClick">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Выйти" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Password change card -->
                        <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel Margin="24">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="🔑" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Безопасность" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>

                                <Button x:Name="ChangePasswordButton"
                                        Content="Изменить пароль"
                                        Height="38"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        Click="ChangePasswordButton_Click"/>

                                <StackPanel x:Name="ChangePasswordPanel"
                                            Margin="0,16,0,0"
                                            Visibility="Collapsed">
                                    <TextBlock Text="Новый пароль" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="NewPasswordBox"
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 Margin="0,0,0,14"/>

                                    <TextBlock Text="Код из письма (6 цифр)" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CodeTextBox"
                                             MaxLength="6"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,16"
                                             FontSize="20" FontWeight="SemiBold"
                                             TextChanged="CodeTextBox_TextChanged"/>

                                    <Button Content="Подтвердить изменение"
                                            Height="38" HorizontalAlignment="Left"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="ConfirmPasswordChangeButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
