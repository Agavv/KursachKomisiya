<Page x:Class="MebelShop.Admin.AddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Добавление товара">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Width="760" HorizontalAlignment="Center" Margin="0,24,0,32">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Добавление нового товара" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Main info card -->
            <Border CornerRadius="10" Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel Margin="24">
                    <TextBlock Text="Основная информация" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Название товара" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="ProductNameTextBox"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Введите название"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Описание" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DescriptionTextBox"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Подробное описание товара"
                             Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CategoryComboBox" Grid.Column="0"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Выберите категорию"
                                  SelectionChanged="CategoryComboBox_SelectionChanged"/>
                        <TextBox x:Name="PriceTextBox" Grid.Column="2"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Цена (₽)"/>
                        <TextBox x:Name="QuantityTextBox" Grid.Column="4"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Количество"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Characteristics card -->
            <Border CornerRadius="10" Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel Margin="24">
                    <TextBlock Text="Характеристики" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel x:Name="CharacteristicsPanel" Orientation="Vertical"/>
                </StackPanel>
            </Border>

            <!-- Photos card -->
            <Border CornerRadius="10" Margin="0,0,0,24"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel Margin="24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Фотографии товара" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="+ Добавить фото"
                                Height="34" Padding="14,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Click="AddImage_Click"/>
                    </StackPanel>
                    <WrapPanel x:Name="ImagesWrapPanel"/>
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Отмена" Height="44" Padding="28,0" Margin="0,0,12,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="Cancel_Click"/>
                <Button Content="✓  Сохранить товар" Height="44" Padding="28,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="SaveProduct_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
