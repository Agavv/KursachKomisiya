<Page x:Class="MebelShop.Admin.CharacteristicsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Характеристики">

    <!-- MC6007 FIX: ContextMenu in Page.Resources -->
    <Page.Resources>
        <ContextMenu x:Key="CharacteristicRowContextMenu">
            <MenuItem Header="✏  Изменить" Click="EditCharacteristic_Click"/>
            <MenuItem Header="🗑  Удалить"  Click="DeleteCharacteristic_Click"/>
        </ContextMenu>
    </Page.Resources>

    <materialDesign:DialogHost x:Name="CharacteristicDialogHost">
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with back button -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="← Назад" Height="36" Padding="14,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Margin="0,0,14,0"
                        Click="BackButton_Click"/>
                <TextBlock x:Name="CharacteristicsTitle"
                           Grid.Column="1"
                           Text="Характеристики категории"
                           FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Search bar -->
            <Border Grid.Row="1" CornerRadius="10" Margin="0,0,0,12"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Margin="16,10">
                    <TextBox x:Name="SearchTextBox" Width="300"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="🔍  Поиск по названию или типу"
                             TextChanged="SearchTextBox_TextChanged"
                             Margin="0,0,12,0"/>
                    <Button Content="✕  Сбросить" Height="40" Padding="14,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Click="Reset_Click"/>
                </StackPanel>
            </Border>

            <!-- DataGrid card -->
            <Border Grid.Row="2" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <DataGrid x:Name="CharacteristicsDataGrid"
                          Margin="4"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          RowHeight="38" SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="10,6"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="10">

                    <!-- ContextMenu from Page.Resources — fixes MC6007 -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource CharacteristicRowContextMenu}"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"           Binding="{Binding IdCharacteristic}" Width="80"/>
                        <DataGridTextColumn Header="Название"     Binding="{Binding Name}"             Width="*"/>
                        <DataGridTextColumn Header="Тип значения" Binding="{Binding ValueType}"        Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Grid.Row="3" Content="+ Добавить характеристику"
                    Height="40" Padding="20,0" HorizontalAlignment="Center" Margin="0,12,0,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="AddCharacteristic_Click"/>
        </Grid>

        <!-- Add / Edit dialog -->
        <materialDesign:DialogHost.DialogContent>
            <StackPanel Margin="24" Width="360">
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                <TextBlock Text="Название" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                <TextBox x:Name="CharacteristicNameTextBox"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Например: Материал, Цвет..."
                         Margin="0,0,0,14"/>
                <TextBlock Text="Тип значения" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                <ComboBox x:Name="ValueTypeComboBox"
                          materialDesign:HintAssist.Hint="Выберите тип"
                          Margin="0,0,0,20">
                    <ComboBoxItem Content="list"/>
                    <ComboBoxItem Content="range"/>
                </ComboBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Margin="0,0,10,0"
                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
                    <Button Content="Сохранить"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="DialogSave_Click"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost.DialogContent>
    </materialDesign:DialogHost>
</Page>
