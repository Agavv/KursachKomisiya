<Page x:Class="MebelShop.Admin.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Товары">

    <!-- MC6007 FIX: ContextMenu in Page.Resources -->
    <Page.Resources>
        <ContextMenu x:Key="ProductRowContextMenu">
            <MenuItem Header="✏  Изменить товар" Click="EditProduct_Click"/>
            <MenuItem Header="🗑  Удалить товар"  Click="DeleteProduct_Click"/>
        </ContextMenu>
    </Page.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Товары" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Search/filter bar -->
        <Border Grid.Row="1" CornerRadius="10" Margin="0,0,0,12"
                Background="{DynamicResource MaterialDesignPaper}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" Margin="16,12">
                <TextBox x:Name="SearchTextBox" Width="220"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="ID или название товара"
                         TextChanged="SearchTextBox_TextChanged"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="SearchCategoryTextBox" Width="220"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="ID или название категории"
                         TextChanged="SearchTextBox_TextChanged"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="PriceTextBox" Width="120"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Цена (макс)"
                         TextChanged="SearchTextBox_TextChanged"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="StockTextBox" Width="120"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Кол-во (макс)"
                         TextChanged="SearchTextBox_TextChanged"
                         Margin="0,0,10,0"/>
                <Button Content="✕  Сбросить" Height="40" Padding="14,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Click="Reset_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid card -->
        <Border Grid.Row="2" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <DataGrid x:Name="ProductsDataGrid"
                      Margin="4"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowHeight="38"
                      SelectionMode="Single"
                      materialDesign:DataGridAssist.CellPadding="10,5"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                      MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">

                <!-- ContextMenu from Page.Resources — fixes MC6007 -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="ContextMenu" Value="{StaticResource ProductRowContextMenu}"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID товара"       Binding="{Binding IdProduct}"    Width="Auto"/>
                    <DataGridTextColumn Header="ID Категории"    Binding="{Binding CategoryId}"   Width="Auto"/>
                    <DataGridTextColumn Header="Название товара" Binding="{Binding ProductName}"  Width="2*"/>
                    <DataGridTextColumn Header="Категория"       Binding="{Binding CategoryName}" Width="*"/>
                    <DataGridTextColumn Header="Описание"        Binding="{Binding Description}"  Width="3*"/>
                    <DataGridTextColumn Header="Цена"            Binding="{Binding Price}"         Width="*"/>
                    <DataGridTextColumn Header="Кол-во"          Binding="{Binding StockQuantity}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="+ Добавить товар"
                    Height="40" Padding="20,0" Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="AddProduct_Click"/>
            <Button Content="📥  Импортировать CSV"
                    Height="40" Padding="20,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="ImportProducts_Click"/>
        </StackPanel>
    </Grid>
</Page>
