<Page x:Class="MebelShop.Admin.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Товары">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     materialDesign:HintAssist.Hint="Поиск по ID товара, названию"
                     TextChanged="SearchTextBox_TextChanged"/>
            
            <TextBox x:Name="SearchCategoryTextBox"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     materialDesign:HintAssist.Hint="Поиск по ID категории, названию"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBox x:Name="PriceTextBox"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     materialDesign:HintAssist.Hint="Цена (макс)"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBox x:Name="StockTextBox"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     materialDesign:HintAssist.Hint="Кол-во (макс)"
                     TextChanged="SearchTextBox_TextChanged"/>

            <Button Content="Сбросить"
                    VerticalAlignment="Center"
                    Width="100"
                    Click="Reset_Click"/>
        </StackPanel>

        <DataGrid x:Name="ProductsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  RowHeight="35"
                  SelectionMode="Single"
                  MouseDoubleClick="ProductsDataGrid_MouseDoubleClick"
                  materialDesign:DataGridAssist.CellPadding="8,4"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID товара" Binding="{Binding IdProduct}" Width="Auto"/>
                <DataGridTextColumn Header="ID Категории" Binding="{Binding CategoryId}" Width="Auto"/>
                <DataGridTextColumn Header="Название товара" Binding="{Binding ProductName}" Width="2*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="3*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding StockQuantity}" Width="*"/>
            </DataGrid.Columns>


            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Изменить товар" Click="EditProduct_Click"/>
                    <MenuItem Header="Удалить товар" Click="DeleteProduct_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" Margin="0 10 0 0">
            <Button Grid.Row="2"
                    Content="Добавить товар"
                    Click="AddProduct_Click"
                    HorizontalAlignment="Center"
                    Margin="0,0,10,0"/>
            <Button Grid.Row="2"
                    Content="Импортировать через CSV"
                    Click="ImportProducts_Click"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Page>
