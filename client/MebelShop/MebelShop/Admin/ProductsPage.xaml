<Page x:Class="MebelShop.Admin.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Товары">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Управление товарами" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filters bar -->
        <Border Grid.Row="1" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}"
                Margin="0,0,0,16" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <WrapPanel Orientation="Horizontal">
                <TextBox x:Name="SearchTextBox"
                         Width="220" Margin="0,0,10,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="🔍 ID или название товара"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBox x:Name="SearchCategoryTextBox"
                         Width="220" Margin="0,0,10,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="🔍 ID или название категории"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBox x:Name="PriceTextBox"
                         Width="140" Margin="0,0,10,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Цена (макс)"
                         TextChanged="SearchTextBox_TextChanged"/>
                <TextBox x:Name="StockTextBox"
                         Width="140" Margin="0,0,10,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Кол-во (макс)"
                         TextChanged="SearchTextBox_TextChanged"/>
                <Button Content="✕ Сбросить"
                        Height="40" Padding="16,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        VerticalAlignment="Center"
                        Click="Reset_Click"/>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="10" ClipToBounds="True"
                Background="{DynamicResource MaterialDesignPaper}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <DataGrid x:Name="ProductsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowHeight="40"
                      SelectionMode="Single"
                      MouseDoubleClick="ProductsDataGrid_MouseDoubleClick"
                      materialDesign:DataGridAssist.CellPadding="10,4"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProduct}" Width="60"/>
                    <DataGridTextColumn Header="ID Кат." Binding="{Binding CategoryId}" Width="70"/>
                    <DataGridTextColumn Header="Название товара" Binding="{Binding ProductName}" Width="2*"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="3*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="90"/>
                    <DataGridTextColumn Header="На складе" Binding="{Binding StockQuantity}" Width="90"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✏ Изменить товар" Click="EditProduct_Click"/>
                        <Separator/>
                        <MenuItem Header="🗑 Удалить товар" Click="DeleteProduct_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="＋  Добавить товар"
                    Height="42" Padding="24,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Margin="0,0,12,0"
                    Click="AddProduct_Click"/>
            <Button Content="📥  Импортировать CSV"
                    Height="42" Padding="24,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="ImportProducts_Click"/>
        </StackPanel>
    </Grid>
</Page>
