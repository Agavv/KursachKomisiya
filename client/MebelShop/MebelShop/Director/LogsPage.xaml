<Page x:Class="MebelShop.Director.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox VerticalAlignment="Center" x:Name="EmailFilterBox" materialDesign:HintAssist.Hint="Email пользователя" Width="200"/>
            <ComboBox VerticalAlignment="Center" x:Name="RoleFilterBox" Width="150" Margin="10,0" materialDesign:HintAssist.Hint="Роль">
                <ComboBoxItem Content="Покупатель"/>
                <ComboBoxItem Content="Менеджер"/>
                <ComboBoxItem Content="Администратор"/>
                <ComboBoxItem Content="Директор"/>
            </ComboBox>
            <DatePicker VerticalAlignment="Center" x:Name="DateFromPicker" materialDesign:HintAssist.Hint="С даты"/>
            <DatePicker VerticalAlignment="Center" x:Name="DateToPicker" materialDesign:HintAssist.Hint="По дату" Margin="10,0"/>
            <TextBox VerticalAlignment="Center" x:Name="DescriptionFilterBox" materialDesign:HintAssist.Hint="Описание содержит..." Width="200"/>
            <Button VerticalAlignment="Center" Content="Поиск" Click="ApplyFilters_Click" Margin="10 0 10 0"/>
            <Button VerticalAlignment="Center" Content="Сбросить" Click="Reset_Click"/>
        </StackPanel>

        <!-- Таблица логов -->
        <DataGrid x:Name="AuditGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdAudit}" Width="Auto"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="3*"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Экспортировать в CSV" Width="200" Margin="0,10,0,0" Click="ExportLogs_Click" HorizontalAlignment="Center"/>
    </Grid>
</Page>

