<Page x:Class="MebelShop.Director.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      mc:Ignorable="d">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="📊" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Отчёты" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl Grid.Row="1" materialDesign:ColorZoneAssist.Mode="PrimaryLight">

            <!-- ========= TAB 1: Продажи и выручка ========= -->
            <TabItem Header="📊  Продажи и выручка">
                <ScrollViewer Margin="0,16,0,0">
                    <StackPanel Margin="0,0,0,24">

                        <!-- Header card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Отчёт по продажам и выручке"
                                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Анализ заказов, выручки и самых популярных товаров за выбранный период."
                                               FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Период:" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <ComboBox x:Name="MonthComboBox" Width="150" Margin="0,0,10,0"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              SelectedValuePath="Content"
                                              SelectedValue="{Binding SelectedMonth}">
                                        <ComboBoxItem Content="Весь период"/>
                                        <ComboBoxItem Content="Январь"/>
                                        <ComboBoxItem Content="Февраль"/>
                                        <ComboBoxItem Content="Март"/>
                                        <ComboBoxItem Content="Апрель"/>
                                        <ComboBoxItem Content="Май"/>
                                        <ComboBoxItem Content="Июнь"/>
                                        <ComboBoxItem Content="Июль"/>
                                        <ComboBoxItem Content="Август"/>
                                        <ComboBoxItem Content="Сентябрь"/>
                                        <ComboBoxItem Content="Октябрь"/>
                                        <ComboBoxItem Content="Ноябрь"/>
                                        <ComboBoxItem Content="Декабрь"/>
                                    </ComboBox>
                                    <ComboBox x:Name="YearComboBox" Width="100" Margin="0,0,12,0"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              SelectedItem="{Binding SelectedYear}"/>
                                    <Button Content="📥  PDF"
                                            Height="40" Padding="16,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="GeneratePdfReport_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- No data notice -->
                        <TextBlock x:Name="NoSalesDataText"
                                   Text="Нет данных за выбранный период"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,20"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                        <!-- Leaders card -->
                        <Border x:Name="SalesTop" CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <StackPanel Margin="20,16">
                                <TextBlock Text="🏆  Лидеры продаж" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Самый продаваемый товар" FontSize="12"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding TopProduct}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Самая продаваемая категория" FontSize="12"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding TopCategory}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Chart card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="16">
                                <lvc:CartesianChart x:Name="SalesChart"
                                                    Series="{Binding SalesChartData}"
                                                    Height="200" MinWidth="400">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Дни месяца" Labels="{Binding SalesDays}">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Выручка (₽)">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </ScrollViewer>
                        </Border>

                        <!-- Data table card -->
                        <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <DataGrid x:Name="SalesDataGrid" Margin="4"
                                      ItemsSource="{Binding SalesTable}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      materialDesign:DataGridAssist.CellPadding="10,6"
                                      materialDesign:DataGridAssist.ColumnHeaderPadding="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата"             Binding="{Binding Date}"     Width="*"/>
                                    <DataGridTextColumn Header="Заказы"           Binding="{Binding Orders}"   Width="*"/>
                                    <DataGridTextColumn Header="Выручка (₽)"      Binding="{Binding Revenue}"  Width="*"/>
                                    <DataGridTextColumn Header="Средний чек (₽)"  Binding="{Binding AvgOrder}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========= TAB 2: Остатки и движение товаров ========= -->
            <TabItem Header="📦  Остатки товаров">
                <ScrollViewer Margin="0,16,0,0">
                    <StackPanel Margin="0,0,0,24">

                        <!-- Header card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Остатки и движение товаров"
                                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Количество товаров на складе и сколько единиц продано. Помогает планировать закупки."
                                               FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ComboBox x:Name="StockFilterComboBox" Width="220" Margin="0,0,12,0"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Сортировка"
                                              SelectionChanged="StockFilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="По умолчанию"/>
                                        <ComboBoxItem Content="Топ проданных товаров"/>
                                        <ComboBoxItem Content="Меньше всего проданных"/>
                                        <ComboBoxItem Content="Осталось мало на складе" IsSelected="True"/>
                                    </ComboBox>
                                    <Button Content="📥  PDF"
                                            Height="40" Padding="16,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="GenerateStockPdfReport_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Chart card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="16">
                                <lvc:CartesianChart x:Name="StockChart"
                                                    Series="{Binding StockChartData}"
                                                    Height="280" MinWidth="500">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Товар" Labels="{Binding StockProductNames}" LabelsRotation="15">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Количество">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </ScrollViewer>
                        </Border>

                        <!-- Table card -->
                        <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <DataGrid x:Name="StockDataGrid" Margin="4"
                                      ItemsSource="{Binding StockTable}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      materialDesign:DataGridAssist.CellPadding="10,6"
                                      materialDesign:DataGridAssist.ColumnHeaderPadding="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"        Binding="{Binding IdProduct}"   Width="60"/>
                                    <DataGridTextColumn Header="Товар"     Binding="{Binding ProductName}" Width="3*"/>
                                    <DataGridTextColumn Header="На складе" Binding="{Binding Stock}"       Width="*"/>
                                    <DataGridTextColumn Header="Продано"   Binding="{Binding Sold}"        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========= TAB 3: Качество товаров ========= -->
            <TabItem Header="⭐  Качество товаров">
                <ScrollViewer Margin="0,16,0,0">
                    <StackPanel Margin="0,0,0,24">

                        <!-- Header card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Качество товаров по отзывам"
                                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Средний рейтинг товаров на основе отзывов покупателей. Выявляет популярные и проблемные позиции."
                                               FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ComboBox x:Name="ReviewsFilterComboBox" Width="260" Margin="0,0,12,0"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Сортировка"
                                              SelectionChanged="ReviewsFilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                                        <ComboBoxItem Content="По средней оценке ↓"/>
                                        <ComboBoxItem Content="По средней оценке ↑"/>
                                        <ComboBoxItem Content="По количеству отзывов ↓"/>
                                        <ComboBoxItem Content="По популярности (рейтинг × отзывы)"/>
                                    </ComboBox>
                                    <Button Content="📥  PDF"
                                            Height="40" Padding="16,0"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            Click="GenerateReviewsPdfReport_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Chart card -->
                        <Border CornerRadius="10" Margin="0,0,0,14"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="16">
                                <lvc:CartesianChart x:Name="ReviewsChart"
                                                    Series="{Binding RatingChartData}"
                                                    Height="280" MinWidth="300">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Товар" Labels="{Binding RatingProductNames}" LabelsRotation="15">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Средняя оценка">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="0.5"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </ScrollViewer>
                        </Border>

                        <!-- Table card -->
                        <Border CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <DataGrid x:Name="ReviewsDataGrid" Margin="4"
                                      ItemsSource="{Binding RatingTable}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      materialDesign:DataGridAssist.CellPadding="10,6"
                                      materialDesign:DataGridAssist.ColumnHeaderPadding="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"               Binding="{Binding IdProduct}"   Width="60"/>
                                    <DataGridTextColumn Header="Товар"            Binding="{Binding ProductName}" Width="3*"/>
                                    <DataGridTextColumn Header="Средний рейтинг"  Binding="{Binding AvgRating}"   Width="*"/>
                                    <DataGridTextColumn Header="Кол-во отзывов"   Binding="{Binding ReviewCount}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
