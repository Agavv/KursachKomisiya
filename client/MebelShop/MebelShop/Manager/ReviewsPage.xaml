<Page x:Class="MebelShop.Manager.ReviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Отзывы">

    <materialDesign:DialogHost x:Name="ReviewDialogHost">
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="💬" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Отзывы покупателей" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Filter bar -->
            <Border Grid.Row="1" CornerRadius="10" Margin="0,0,0,14"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Margin="16,12">
                    <ComboBox x:Name="RatingFilterComboBox" Width="160" Margin="0,0,12,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Рейтинг"
                              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Все оценки" IsSelected="True"/>
                        <ComboBoxItem Content="★★★★★  5"/>
                        <ComboBoxItem Content="★★★★☆  4"/>
                        <ComboBoxItem Content="★★★☆☆  3"/>
                        <ComboBoxItem Content="★★☆☆☆  2"/>
                        <ComboBoxItem Content="★☆☆☆☆  1"/>
                    </ComboBox>
                    <ComboBox x:Name="DateFilterComboBox" Width="180" Margin="0,0,12,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Период"
                              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Все даты" IsSelected="True"/>
                        <ComboBoxItem Content="За последние 7 дней"/>
                        <ComboBoxItem Content="За месяц"/>
                        <ComboBoxItem Content="За год"/>
                    </ComboBox>
                    <Button Content="✕  Сбросить"
                            Height="40" Padding="14,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Click="ResetFilters_Click"/>
                </StackPanel>
            </Border>

            <!-- Reviews masonry/wrap grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ReviewsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="320" Margin="0,0,14,14" CornerRadius="12"
                                    Background="{DynamicResource MaterialDesignPaper}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.09" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: avatar + user info -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="76" Height="76" CornerRadius="8"
                                                ClipToBounds="True" Background="#F5F5F5">
                                            <Image Source="{Binding ProductImageUrl}"
                                                   Stretch="UniformToFill"
                                                   Cursor="Hand"
                                                   MouseLeftButtonUp="Image_MouseLeftButtonUp"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,4,0,0">
                                            <TextBlock Text="{Binding UserName}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       Margin="0,3,0,6"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" Foreground="#FFC107" FontSize="15"/>
                                                <TextBlock Text="{Binding Rating}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 1: comment -->
                                    <Border Grid.Row="1" CornerRadius="6" Background="#F8F9FA"
                                            Padding="10,8" Margin="0,10,0,0">
                                        <ScrollViewer MaxHeight="72" VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       LineHeight="20"/>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Row 2: action buttons -->
                                    <Grid Grid.Row="2" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="{Binding ReplyButtonText}"
                                                Height="34"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Click="ReplyButton_Click"/>
                                        <Button Grid.Column="2"
                                                Content="Удалить"
                                                Height="34"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Foreground="#EF5350"
                                                BorderBrush="#EF5350"
                                                Click="DeleteButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Reply dialog -->
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="24" Width="420" CornerRadius="10"
                    Background="{DynamicResource MaterialDesignPaper}">
                <StackPanel>
                    <TextBlock Text="Ответ на отзыв"
                               FontWeight="Bold" FontSize="18" Margin="0,0,0,16"/>
                    <TextBox x:Name="DialogResponseTextBox"
                             Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Введите ответ клиенту..."
                             Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Margin="0,0,10,0"
                                Click="DialogCancel_Click"/>
                        <Button Content="Отправить ответ"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Click="DialogSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    </materialDesign:DialogHost>
</Page>
