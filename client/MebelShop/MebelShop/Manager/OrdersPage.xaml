<Page x:Class="MebelShop.Manager.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="Заказы"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <materialDesign:DialogHost Identifier="RootDialog" x:Name="OrdersDialogHost">

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Заказы" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Filter bar card -->
            <Border Grid.Row="1" CornerRadius="10" Margin="0,0,0,14"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="OrderIdTextBox"    Grid.Column="0" Margin="0,0,6,0"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="ID заказа"/>
                    <TextBox x:Name="UserIdTextBox"     Grid.Column="1" Margin="0,0,6,0"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="ID пользователя"/>
                    <TextBox x:Name="FirstNameTextBox"  Grid.Column="2" Margin="0,0,6,0"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Имя"/>
                    <TextBox x:Name="LastNameTextBox"   Grid.Column="3" Margin="0,0,6,0"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Фамилия"/>
                    <DatePicker x:Name="DateFromPicker" Grid.Column="4" Margin="0,0,6,0"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                materialDesign:HintAssist.Hint="Дата от"/>
                    <DatePicker x:Name="DateToPicker"   Grid.Column="5" Margin="0,0,6,0"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                materialDesign:HintAssist.Hint="Дата до"/>
                    <ComboBox x:Name="StatusComboBox"       Grid.Column="6" Margin="0,0,6,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Статус">
                        <ComboBoxItem Content="Все (статус)" IsSelected="True"/>
                        <ComboBoxItem Content="Создан"/>
                        <ComboBoxItem Content="Отправлен"/>
                        <ComboBoxItem Content="Получен"/>
                        <ComboBoxItem Content="Отменен"/>
                    </ComboBox>
                    <ComboBox x:Name="DeliveryTypeComboBox" Grid.Column="7" Margin="0,0,6,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Доставка">
                        <ComboBoxItem Content="Все (доставка)" IsSelected="True"/>
                        <ComboBoxItem Content="Самовывоз"/>
                        <ComboBoxItem Content="Доставка по адресу"/>
                    </ComboBox>
                    <ComboBox x:Name="PaymentTypeComboBox"  Grid.Column="8" Margin="0,0,6,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Оплата">
                        <ComboBoxItem Content="Все (оплата)" IsSelected="True"/>
                        <ComboBoxItem Content="Онлайн"/>
                        <ComboBoxItem Content="При получении"/>
                    </ComboBox>
                    <Button Content="✕  Сбросить" Grid.Column="9"
                            Height="40" Padding="14,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            Click="ResetFilters_Click"/>
                </Grid>
            </Border>

            <!-- Orders data grid in a card -->
            <Border Grid.Row="2" CornerRadius="10"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <DataGrid x:Name="OrdersDataGrid"
                          Margin="4"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="10,6"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                          MouseDoubleClick="OrdersDataGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Изменить статус заказа" Click="ChangeStatus_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID заказа"       Binding="{Binding IdOrder}"          Width="*"/>
                        <DataGridTextColumn Header="ID пользователя" Binding="{Binding UserId}"           Width="*"/>
                        <DataGridTextColumn Header="Имя"             Binding="{Binding FirstName}"        Width="*"/>
                        <DataGridTextColumn Header="Фамилия"         Binding="{Binding LastName}"         Width="*"/>
                        <DataGridTextColumn Header="Дата создания"   Binding="{Binding CreatedAt}"        Width="*"/>
                        <DataGridTextColumn Header="Статус"          Binding="{Binding Status}"           Width="*"/>
                        <DataGridTextColumn Header="Доставка"        Binding="{Binding DeliveryType}"     Width="*"/>
                        <DataGridTextColumn Header="Адрес"           Binding="{Binding DeliveryAddress}"  Width="*"/>
                        <DataGridTextColumn Header="Оплата"          Binding="{Binding PaymentType}"      Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Status change dialog -->
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="24" Width="360" CornerRadius="10"
                    Background="{DynamicResource MaterialDesignPaper}">
                <StackPanel>
                    <TextBlock Text="Изменить статус заказа"
                               FontWeight="Bold" FontSize="18" Margin="0,0,0,16"/>
                    <TextBlock Text="Новый статус" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DialogStatusComboBox"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Выберите статус"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Отправлен"/>
                        <ComboBoxItem Content="Получен"/>
                        <ComboBoxItem Content="Отменен"/>
                    </ComboBox>
                    <TextBlock Text="Комментарий" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DialogCommentTextBox"
                             AcceptsReturn="True" Height="70"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Необязательно"
                             Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Margin="0,0,10,0"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
                        <Button Content="Сохранить"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Click="SaveStatus_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    </materialDesign:DialogHost>
</Page>
