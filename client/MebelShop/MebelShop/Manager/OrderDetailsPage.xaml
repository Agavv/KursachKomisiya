<Page x:Class="MebelShop.Manager.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Детали заказа"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="← Назад" Width="100" Click="BackButton_Click"/>
            <TextBlock x:Name="OrderNumberText" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid MouseDoubleClick="OrderItemsDataGrid_MouseDoubleClick" x:Name="OrderItemsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID товара" Binding="{Binding ProductId}" Width="*"/>
                <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="2*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="*"/>
                <DataGridTextColumn Header="Осталось на складе" Binding="{Binding StockQuantity}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
