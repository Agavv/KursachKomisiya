<Page x:Class="MebelShop.Manager.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Детали заказа"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="← Назад" Height="36" Padding="16,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="BackButton_Click"/>
            <TextBlock x:Name="OrderNumberText"
                       FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Data grid in a card -->
        <Border Grid.Row="1" CornerRadius="10"
                Background="{DynamicResource MaterialDesignPaper}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.07" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <DataGrid x:Name="OrderItemsDataGrid"
                      Margin="8"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="10,6"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10"
                      MouseDoubleClick="OrderItemsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID товара"    Binding="{Binding ProductId}"     Width="*"/>
                    <DataGridTextColumn Header="Название"     Binding="{Binding ProductName}"    Width="3*"/>
                    <DataGridTextColumn Header="Кол-во"       Binding="{Binding Quantity}"        Width="*"/>
                    <DataGridTextColumn Header="Цена"         Binding="{Binding UnitPrice}"       Width="*"/>
                    <DataGridTextColumn Header="Остаток"      Binding="{Binding StockQuantity}"   Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
