<Page x:Class="MebelShop.Auth.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="Transparent"
      Title="Вход">

    <!-- Outer card -->
    <Border Width="820" CornerRadius="16"
            Background="{DynamicResource MaterialDesignPaper}">
        <Border.Effect>
            <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="30" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT decorative panel -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                        <GradientStop Color="#546E7A" Offset="0"/>
                        <GradientStop Color="#37474F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <!-- Logo icon placeholder -->
                    <TextBlock Text="🪑" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="MebelShop" FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <Border Height="2" Width="60" Background="#FFC107" Margin="0,12,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Магазин мебели премиум класса"
                               FontSize="13" Foreground="#B0BEC5"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- RIGHT form panel -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="45,50">
                <TextBlock Text="Добро пожаловать" FontSize="26" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Войдите в свой аккаунт" FontSize="13"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0,0,0,28"/>

                <TextBlock Text="Email" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailTextBox"
                         materialDesign:HintAssist.Hint="example@mail.com"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         Text="admin@gmail.com"/>

                <TextBlock Text="Пароль" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Введите пароль"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,28"
                             Password="RootPassword321"/>

                <Button Content="Войти"
                        Height="44"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="LoginButton_Click"/>

                <Border Height="1" Background="#EEEEEE" Margin="0,20,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Нет аккаунта? Зарегистрируйтесь"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            FontSize="12"
                            Margin="0,0,8,0"
                            Click="Register_Click"/>
                    <TextBlock Text="·" VerticalAlignment="Center" Foreground="Gray"/>
                    <Button Content="Забыли пароль?"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            FontSize="12"
                            Margin="8,0,0,0"
                            Click="ForgotPassword_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Page>
