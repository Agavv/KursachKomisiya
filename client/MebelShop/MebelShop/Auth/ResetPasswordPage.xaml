<Page x:Class="MebelShop.Auth.ResetPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="Transparent"
      Title="Восстановление пароля">

    <Border Width="820" CornerRadius="16"
            Background="{DynamicResource MaterialDesignPaper}">
        <Border.Effect>
            <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="30" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT panel -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                        <GradientStop Color="#546E7A" Offset="0"/>
                        <GradientStop Color="#37474F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <TextBlock Text="🔑" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Восстановление" FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Border Height="2" Width="60" Background="#FFC107" Margin="0,12,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Сбросьте пароль в несколько шагов" FontSize="13" Foreground="#B0BEC5"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- RIGHT form -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="45,50">
                <TextBlock x:Name="TitleText" Text="Восстановление пароля"
                           FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Следуйте инструкциям для сброса пароля" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,28"/>

                <StackPanel x:Name="StepEmail">
                    <TextBlock Text="Email адрес" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="EmailTextBox"
                             materialDesign:HintAssist.Hint="Укажите email вашего аккаунта"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,22"/>
                    <Button Content="Отправить код на почту"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="SendCode_Click"/>
                </StackPanel>

                <StackPanel x:Name="StepCode" Visibility="Collapsed">
                    <TextBlock Text="Код из письма" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CodeTextBox"
                             materialDesign:HintAssist.Hint="6-значный код"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="22" FontWeight="SemiBold"
                             Margin="0,0,0,22"/>
                    <Button Content="Подтвердить код"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="VerifyCode_Click"/>
                </StackPanel>

                <StackPanel x:Name="StepPassword" Visibility="Collapsed">
                    <TextBlock Text="Новый пароль" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 materialDesign:HintAssist.Hint="Введите новый пароль"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,14"/>
                    <TextBlock Text="Подтверждение пароля" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 materialDesign:HintAssist.Hint="Повторите новый пароль"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,22"/>
                    <Button Content="Сохранить новый пароль"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="SavePassword_Click"/>
                </StackPanel>

                <Border Height="1" Background="#EEEEEE" Margin="0,20,0,8"/>
                <Button Content="← Вернуться ко входу"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Click="BackToLogin_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Page>
