<Page x:Class="MebelShop.Auth.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="Transparent"
      Title="Регистрация">

    <Border Width="820" CornerRadius="16"
            Background="{DynamicResource MaterialDesignPaper}">
        <Border.Effect>
            <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="30" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT panel -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                        <GradientStop Color="#546E7A" Offset="0"/>
                        <GradientStop Color="#37474F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <TextBlock Text="🪑" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="MebelShop" FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <Border Height="2" Width="60" Background="#FFC107" Margin="0,12,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Создайте аккаунт для покупок" FontSize="13" Foreground="#B0BEC5"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- RIGHT form -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="45,45">

                <!-- Step 1 -->
                <StackPanel x:Name="Step1Panel">
                    <TextBlock Text="Создать аккаунт" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="Шаг 1 из 3 — Данные для входа" FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,24"/>

                    <TextBlock Text="Email" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="EmailTextBox"
                             materialDesign:HintAssist.Hint="example@mail.com"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Пароль" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox"
                                 materialDesign:HintAssist.Hint="Минимум 8 символов"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="Подтверждение пароля" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 materialDesign:HintAssist.Hint="Повторите пароль"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,22"/>

                    <Button Content="Продолжить →"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="Step1Next_Click"/>
                </StackPanel>

                <!-- Step 2 -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock Text="Подтверждение Email" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="Шаг 2 из 3 — Введите код из письма" FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,24"/>

                    <TextBlock Text="6-значный код" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CodeTextBox"
                             materialDesign:HintAssist.Hint="Например: 123456"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="22" FontWeight="SemiBold"
                             Margin="0,0,0,22"/>

                    <Button Content="Подтвердить"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="Step2Confirm_Click"/>
                </StackPanel>

                <!-- Step 3 -->
                <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                    <TextBlock Text="Ваш профиль" FontSize="26" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="Шаг 3 из 3 — Имя и фамилия (необязательно)" FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,24"/>

                    <TextBlock Text="Имя" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="FirstNameTextBox"
                             materialDesign:HintAssist.Hint="Ваше имя"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Фамилия" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                    <TextBox x:Name="LastNameTextBox"
                             materialDesign:HintAssist.Hint="Ваша фамилия"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,22"/>

                    <Button Content="Завершить регистрацию ✓"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Click="Step3Finish_Click"/>
                </StackPanel>

                <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="0,18,0,8"/>
                <Button Content="Уже есть аккаунт? Войти"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Click="Login_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Page>
