<Page x:Class="MebelShop.Admin.CharacteristicsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Характеристики">

    <materialDesign:DialogHost x:Name="CharacteristicDialogHost">

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0, 0, 0, 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!-- Заголовок -->
                <Button Content="Назад" VerticalAlignment="Center" Margin="0, 0, 10, 0" Click="BackButton_Click"/>
                <TextBlock Text="Характеристики категории"
                           VerticalAlignment="Center"
                           Grid.Column="1"
                           FontSize="20"
                           FontWeight="Bold"
                           x:Name="CharacteristicsTitle"/>
            </Grid>

            <!-- Поиск -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.Row="1">
                <TextBox x:Name="SearchTextBox"
                         Width="250"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по названию или типу"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Сбросить"
                        Click="Reset_Click"/>
            </StackPanel>

            <!-- Таблица -->
            <DataGrid x:Name="CharacteristicsDataGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowHeight="35"
                      SelectionMode="Single"
                      Margin="0,5,0,5"
                      materialDesign:DataGridAssist.CellPadding="8,4"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdCharacteristic}" Width="80"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Тип значения" Binding="{Binding ValueType}" Width="150"/>
                </DataGrid.Columns>

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Изменить" Click="EditCharacteristic_Click"/>
                        <MenuItem Header="Удалить" Click="DeleteCharacteristic_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <!-- Кнопка добавления -->
            <Button Grid.Row="3"
                    Content="Добавить характеристику"
                    Click="AddCharacteristic_Click"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"/>
        </Grid>

        <!-- Диалог добавления/редактирования -->
        <materialDesign:DialogHost.DialogContent>
            <StackPanel Margin="20">
                <TextBlock Text="{Binding DialogTitle}" FontSize="18" Margin="0,0,0,10"/>

                <TextBox x:Name="CharacteristicNameTextBox"
                         materialDesign:HintAssist.Hint="Название характеристики"
                         Margin="0,0,0,15"/>

                <ComboBox x:Name="ValueTypeComboBox"
                          materialDesign:HintAssist.Hint="Тип значения"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="list"/>
                    <ComboBoxItem Content="range"/>
                </ComboBox>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Отмена"
                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                            Margin="0,0,5,0"/>
                    <Button Grid.Column="1"
                            Content="Сохранить"
                            Click="DialogSave_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </Grid>
            </StackPanel>
        </materialDesign:DialogHost.DialogContent>
    </materialDesign:DialogHost>
</Page>
