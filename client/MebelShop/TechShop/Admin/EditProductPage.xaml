<Page x:Class="MebelShop.Admin.EditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Изменение товара">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Width="700" HorizontalAlignment="Center">

            <TextBlock Text="Изменение товара" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBox x:Name="ProductNameTextBox"
                     materialDesign:HintAssist.Hint="Название товара"
                     Margin="0,0,0,15"/>

            <TextBox x:Name="DescriptionTextBox"
                     materialDesign:HintAssist.Hint="Описание товара"
                     Margin="0,0,0,15"
                     Height="100"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="CategoryComboBox"
                          Grid.Column="0"
                          Margin="0,0,10,0"
                          SelectionChanged="CategoryComboBox_SelectionChanged"
                          materialDesign:HintAssist.Hint="Выберите категорию"/>
                <TextBox x:Name="PriceTextBox"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Цена"/>
                <TextBox x:Name="QuantityTextBox"
                         Grid.Column="2"
                         materialDesign:HintAssist.Hint="Количество"/>
            </Grid>

            <StackPanel x:Name="CharacteristicsPanel"
                        Margin="0,10,0,20"
                        Orientation="Vertical"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Фотографии товара" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Button Content="Добавить фото"
                        Click="AddImage_Click"
                        Width="150"/>
            </StackPanel>
            <WrapPanel x:Name="ImagesWrapPanel" Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <Button Content="Сохранить изменения"
                        Margin="5"
                        Click="SaveProduct_Click"/>
                <Button Content="Удалить товар"
                        Margin="5"
                        Click="DeleteProduct_Click"/>
                <Button Content="Отмена"
                        Margin="5"
                        Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>