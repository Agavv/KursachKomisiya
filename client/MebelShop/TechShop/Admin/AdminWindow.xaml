<Window x:Class="MebelShop.Admin.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MebelShop.Customer"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MebelShop: Администратор" MinWidth="1024" MinHeight="720"
        Closing="Window_Closing">
    <DockPanel >

        <Grid DockPanel.Dock="Top" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*" />
                <ColumnDefinition Width="40*" />
                <ColumnDefinition Width="40*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Категории" Margin="5"
                Click="CategoriesButton_Click"/>
            <Button Grid.Column="1" Content="Товары" Margin="5"
                Click="ProductsButton_Click"/>
            <Button Grid.Column="2" Content="Управление БД" Margin="5"
                Click="DatabaseButton_Click"/>
            <Button Grid.Column="3" Content="Выйти из аккаунта" Margin="5"
                Click="LogoutButton_Click"/>
            <Button Grid.Column="4" Content="{DynamicResource ThemeIcon}" Width="50" Height="30" Margin="5"
                Style="{StaticResource MaterialDesignFlatButton}"
                Click="ToggleTheme_Click"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="Pink" Margin="0,0,0,5"/>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />

    </DockPanel>
</Window>
