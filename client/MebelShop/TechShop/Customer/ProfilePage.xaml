<Page x:Class="MebelShop.Customer.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Профиль">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Мой профиль"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TabControl Grid.Row="1"
                    TabStripPlacement="Top"
                    Margin="0,10,0,0">

            <TabItem Header="Мои заказы">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="OrdersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Orange" BorderThickness="1" Padding="12" Margin="0,8"
                            Background="{DynamicResource MaterialDesignCardBackground}" MouseLeftButtonUp="Border_MouseLeftButtonUp" Cursor="Hand">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding OrderId, StringFormat='Заказ №{0}'}"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                       Foreground="Gray"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" Text="{Binding Status}" 
                                                       Foreground="Orange"
                                                       FontWeight="SemiBold"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>


                                        <ItemsControl ItemsSource="{Binding ProductImages}" Margin="0,10,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Image Source="{Binding}" 
                                               Width="60" Height="60" 
                                               Margin="0,0,6,0"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <DockPanel Margin="0,10,0,0">
                                            <TextBlock Text="{Binding TotalPrice, StringFormat='Итого: {0:N2} ₽'}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="Orange"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Мои товары">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MyProductsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Orange" BorderThickness="1" Padding="10" Margin="0,10,0,0" 
                            MouseLeftButtonUp="BorderProduct_MouseLeftButtonUp" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0" Source="{Binding MainImageUrl}" 
                                   Width="60" Height="60" Margin="0,0,8,0" Stretch="UniformToFill"/>

                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" 
                                       VerticalAlignment="Center" FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='{}{0:N2} ₽'}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8, 0"/>

                                        <Button Content="{Binding CartButtonText}"
                                                Click="CartButton_Click"
                                                DataContext="{Binding}"
                                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                                Grid.Column="3"/>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Мои отзывы">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MyReviewsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Orange" BorderThickness="1" Padding="12" Margin="0,8"
                            Background="{DynamicResource MaterialDesignCardBackground}" Cursor="Hand" MouseLeftButtonUp="BorderReviews_MouseLeftButtonUp">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding ProductImageUrl}" Width="60" Height="60" Stretch="UniformToFill"
                                   Margin="0,0,10,0"/>

                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>

                                            <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" MaxWidth="400" Margin="0,0,0,5"/>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Rating, StringFormat=Рейтинг: {0} ⭐}" Foreground="Orange" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Foreground="Gray"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Настройки профиля">
                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="20" Width="400" VerticalAlignment="Top" HorizontalAlignment="Center" >
                        <TextBlock Text="Имя" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="FirstNameTextBox" 
                                 TextChanged="FirstNameTextBox_TextChanged"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Фамилия" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="LastNameTextBox" 
                                 TextChanged="LastNameTextBox_TextChanged"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="SaveProfileButton" 
                                    Content="Сохранить изменения" 
                                    IsEnabled="False"
                                    Click="SaveProfileButton_Click"/>

                            <Button x:Name="ChangePasswordButton"
                                    Content="Изменить пароль"
                                    Click="ChangePasswordButton_Click"
                                    Margin="10, 0"/>

                            <Button Click="Logout_ButtonClick">
                                <materialDesign:PackIcon Kind="Logout"/>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="ChangePasswordPanel"
                                    Margin="0,20,0,0"
                                    Visibility="Collapsed">

                            <TextBlock Text="Новый пароль" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="NewPasswordBox"
                                        Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                        Margin="0,0,0,15"/>


                            <TextBlock Text="Код отправленный на e-mail (6 цифр)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="CodeTextBox" 
                                     MaxLength="6"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     Margin="0,0,0,20"
                                     TextChanged="CodeTextBox_TextChanged"/>

                            <Button Content="Подтвердить"
                                    HorizontalAlignment="Center"
                                    Click="ConfirmPasswordChangeButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
