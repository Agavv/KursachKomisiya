<Page x:Class="MebelShop.Director.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      mc:Ignorable="d">

    <Grid Margin="20">
        <TabControl>
            <TabItem Header="📊 Продажи и выручка">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Отчёт по продажам и выручке"
                                   FontSize="20" FontWeight="Bold" Margin="0 0 0 10"/>
                        <TextBlock Text="Анализ заказов, выручки и самых популярных товаров за выбранный период."
                                   TextWrapping="Wrap" Margin="0 0 0 15"/>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                            <TextBlock Text="Выберите период:" VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <ComboBox x:Name="MonthComboBox"
                                      Width="150"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding SelectedMonth}">
                                <ComboBoxItem Content="Весь период"/>
                                <ComboBoxItem Content="Январь"/>
                                <ComboBoxItem Content="Февраль"/>
                                <ComboBoxItem Content="Март"/>
                                <ComboBoxItem Content="Апрель"/>
                                <ComboBoxItem Content="Май"/>
                                <ComboBoxItem Content="Июнь"/>
                                <ComboBoxItem Content="Июль"/>
                                <ComboBoxItem Content="Август"/>
                                <ComboBoxItem Content="Сентябрь"/>
                                <ComboBoxItem Content="Октябрь"/>
                                <ComboBoxItem Content="Ноябрь"/>
                                <ComboBoxItem Content="Декабрь"/>
                            </ComboBox>

                            <ComboBox x:Name="YearComboBox" Width="100" SelectedItem="{Binding SelectedYear}" Margin="10 0 10 0"/>
                            <Button Content="Сформировать отчёт в PDF"
                                    Click="GeneratePdfReport_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="NoSalesDataText"
                                   Text="Нет данных за выбранный период"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0 20"
                                   Visibility="Collapsed"/>

                        <Border x:Name="SalesTop" BorderBrush="Pink" BorderThickness="1" Padding="10" Margin="0 0 0 20">
                            <StackPanel>
                                <TextBlock Text="🏆 Лидеры продаж" FontWeight="Bold" FontSize="16" Margin="0 0 0 5"/>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                    <TextBlock Text="Самый продаваемый товар:" FontWeight="Bold" Margin="0 0 10 0"/>
                                    <TextBlock Text="{Binding TopProduct}" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Самая продаваемая категория:" FontWeight="Bold" Margin="0 0 10 0"/>
                                    <TextBlock Text="{Binding TopCategory}" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <lvc:CartesianChart x:Name="SalesChart" Series="{Binding SalesChartData}" Height="150" MinWidth="300" Margin="0 0 0 15">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Дни месяца" Labels="{Binding SalesDays}" >
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Выручка (₽)" >
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </ScrollViewer>
                        </Grid>

                        <DataGrid x:Name="SalesDataGrid" ItemsSource="{Binding SalesTable}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="*"/>
                                <DataGridTextColumn Header="Заказы" Binding="{Binding Orders}" Width="*"/>
                                <DataGridTextColumn Header="Выручка (₽)" Binding="{Binding Revenue}" Width="*"/>
                                <DataGridTextColumn Header="Средний чек (₽)" Binding="{Binding AvgOrder}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. Отчёт по остаткам и движению товаров -->
            <TabItem Header="📦 Остатки и движение товаров">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Отчёт по остаткам и движению товаров"
                                   FontSize="20" FontWeight="Bold" Margin="0 0 0 10"/>
                        <TextBlock Text="Показывает количество товаров на складе и сколько единиц продано. Помогает планировать закупки и контролировать запасы."
                                   TextWrapping="Wrap" Margin="0 0 0 20"/>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                            <TextBlock Text="Сортировка:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="StockFilterComboBox" 
                                      SelectionChanged="StockFilterComboBox_SelectionChanged"
                                      MinWidth="200" Margin="10 0">
                                <ComboBoxItem Content="По умолчанию"/>
                                <ComboBoxItem Content="Топ проданных товаров"/>
                                <ComboBoxItem Content="Меньше всего проданных товаров"/>
                                <ComboBoxItem Content="Осталось мало на складе" IsSelected="True"/>
                            </ComboBox>
                            <Button Content="Сформировать отчёт в PDF" Click="GenerateStockPdfReport_Click"/>
                        </StackPanel>
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <lvc:CartesianChart x:Name="StockChart" Series="{Binding StockChartData}" Height="300" MinWidth="500" Margin="0 0 0 15">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Товар" Labels="{Binding StockProductNames}" LabelsRotation="15">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Количество">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </ScrollViewer>
                        </Grid>

                        <DataGrid x:Name="StockDataGrid" ItemsSource="{Binding StockTable}" AutoGenerateColumns="False" Margin="0 15 0 0" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding IdProduct}"/>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="На складе" Binding="{Binding Stock}" Width="*"/>
                                <DataGridTextColumn Header="Продано" Binding="{Binding Sold}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. Отчёт по качеству товаров -->
            <TabItem Header="⭐ Качество товаров">
                <StackPanel Margin="10">
                    <TextBlock Text="Отчёт по качеству товаров"
                               FontSize="20" FontWeight="Bold" Margin="0 0 0 10"/>
                    <TextBlock Text="Средний рейтинг товаров на основе отзывов покупателей. Позволяет выявить популярные и проблемные товары."
                               TextWrapping="Wrap" Margin="0 0 0 20"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <TextBlock Text="Сортировка:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ReviewsFilterComboBox" 
                                  MinWidth="200" Margin="10 0"
                                  SelectionChanged="ReviewsFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                            <ComboBoxItem Content="По средней оценке (по убыванию)"/>
                            <ComboBoxItem Content="По средней оценке (по возрастанию)"/>
                            <ComboBoxItem Content="По количеству отзывов (по убыванию)"/>
                            <ComboBoxItem Content="По популярности (рейтинг * отзывы)"/>
                        </ComboBox>
                        <Button Content="Сформировать отчёт в PDF" Click="GenerateReviewsPdfReport_Click"/>
                    </StackPanel>
                    <Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <lvc:CartesianChart x:Name="ReviewsChart" Series="{Binding RatingChartData}" Height="300" MinWidth="200" Margin="0 0 0 15">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Товар" Labels="{Binding RatingProductNames}" LabelsRotation="15">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Средняя оценка">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="Gray" StrokeThickness="1"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </ScrollViewer>
                    </Grid>

                    <DataGrid x:Name="ReviewsDataGrid" ItemsSource="{Binding RatingTable}" AutoGenerateColumns="False" Margin="0 15 0 0" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdProduct}"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Средний рейтинг" Binding="{Binding AvgRating}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во отзывов" Binding="{Binding ReviewCount}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Page>