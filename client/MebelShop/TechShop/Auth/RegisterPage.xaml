<Page x:Class="MebelShop.Auth.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
              Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Регистрация">
    <Border Width="400" Padding="30" CornerRadius="10">
        <StackPanel>
            <StackPanel x:Name="Step1Panel">
                <TextBlock Text="Регистрация" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBox x:Name="EmailTextBox"
                             materialDesign:HintAssist.Hint="Email"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                <PasswordBox x:Name="PasswordBox"
                                 materialDesign:HintAssist.Hint="Пароль"
                                 Margin="0,0,0,15"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>

                <PasswordBox x:Name="ConfirmPasswordBox"
                                 materialDesign:HintAssist.Hint="Подтвердите пароль"
                                 Margin="0,0,0,15"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>

                <Button Content="Далее"
                            Margin="0,10,0,5"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="Step1Next_Click"/>
            </StackPanel>

            <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                <TextBlock Text="Подтверждение Email" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBox x:Name="CodeTextBox"
                             materialDesign:HintAssist.Hint="Введите 6-значный код"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                <Button Content="Подтвердить"
                            Margin="0,10,0,5"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="Step2Confirm_Click"/>
            </StackPanel>

            <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                <TextBlock Text="Дополнительно" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBox x:Name="FirstNameTextBox"
                             materialDesign:HintAssist.Hint="Имя (опционально)"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                <TextBox x:Name="LastNameTextBox"
                             materialDesign:HintAssist.Hint="Фамилия (опционально)"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                <Button Content="Завершить регистрацию"
                            Margin="0,10,0,5"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="Step3Finish_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Уже есть аккаунт?"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Login_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Page>
