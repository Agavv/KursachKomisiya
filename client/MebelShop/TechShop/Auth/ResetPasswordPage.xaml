<Page x:Class="MebelShop.Auth.ResetPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
              Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Title="Восстановление пароля">

    <Border Width="400" Padding="30" CornerRadius="10">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Восстановление пароля"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <StackPanel x:Name="StepEmail">
                <TextBox x:Name="EmailTextBox"
                         materialDesign:HintAssist.Hint="Введите email"
                         Margin="0,0,0,15"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                <Button Content="Отправить код"
                        Height="40"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="SendCode_Click"/>
            </StackPanel>

            <StackPanel x:Name="StepCode" Visibility="Collapsed">
                <TextBox x:Name="CodeTextBox"
                         materialDesign:HintAssist.Hint="Введите код из письма"
                         Margin="0,0,0,15"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                <Button Content="Подтвердить код"
                        Height="40"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="VerifyCode_Click"/>
            </StackPanel>

            <StackPanel x:Name="StepPassword" Visibility="Collapsed">
                <PasswordBox x:Name="NewPasswordBox"
                             materialDesign:HintAssist.Hint="Новый пароль"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             materialDesign:HintAssist.Hint="Подтвердите пароль"
                             Margin="0,0,0,15"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                <Button Content="Сохранить новый пароль"
                        Height="40"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="SavePassword_Click"/>
            </StackPanel>

            <Button Content="Назад"
                    Margin="0,20,0,0"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="BackToLogin_Click"/>
        </StackPanel>
    </Border>
</Page>
