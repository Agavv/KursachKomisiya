<Page x:Class="MebelShop.Manager.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="Заказы"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <!-- DialogHost оборачивает весь контент -->
    <materialDesign:DialogHost Identifier="RootDialog" x:Name="OrdersDialogHost">

        <!-- Основное содержимое страницы -->
        <DockPanel Margin="10">

            <!-- Панель фильтров -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="OrderIdTextBox" Grid.Column="0"
                         materialDesign:HintAssist.Hint="ID заказа" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="UserIdTextBox" Grid.Column="1"
                         materialDesign:HintAssist.Hint="ID пользователя" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="FirstNameTextBox" Grid.Column="2"
                         materialDesign:HintAssist.Hint="Имя" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="LastNameTextBox" Grid.Column="3"
                         materialDesign:HintAssist.Hint="Фамилия" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <DatePicker x:Name="DateFromPicker" Grid.Column="4"
                            materialDesign:HintAssist.Hint="Дата от" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <DatePicker x:Name="DateToPicker" Grid.Column="5"
                            materialDesign:HintAssist.Hint="Дата до" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="StatusComboBox" Grid.Column="6" Margin="0,0,5,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="Все (статус)" IsSelected="True"/>
                    <ComboBoxItem Content="Создан"/>
                    <ComboBoxItem Content="Отправлен"/>
                    <ComboBoxItem Content="Получен"/>
                    <ComboBoxItem Content="Отменен"/>
                </ComboBox>
                <ComboBox x:Name="DeliveryTypeComboBox" Grid.Column="7" Margin="0,0,5,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="Все (доставка)" IsSelected="True"/>
                    <ComboBoxItem Content="Самовывоз"/>
                    <ComboBoxItem Content="Доставка по адресу"/>
                </ComboBox>
                <ComboBox x:Name="PaymentTypeComboBox" Grid.Column="8" Margin="0,0,5,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="Все (оплата)" IsSelected="True"/>
                    <ComboBoxItem Content="Онлайн"/>
                    <ComboBoxItem Content="При получении"/>
                </ComboBox>
                <Button Content="Сбросить" Grid.Column="9" Click="ResetFilters_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- Таблица заказов -->
            <DataGrid x:Name="OrdersDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      Margin="0,10,0,0"
                      MouseDoubleClick="OrdersDataGrid_MouseDoubleClick">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Изменить статус заказа" Click="ChangeStatus_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID заказа" Binding="{Binding IdOrder}" Width="*"/>
                    <DataGridTextColumn Header="ID пользователя" Binding="{Binding UserId}" Width="*"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                    <DataGridTextColumn Header="Способ доставки" Binding="{Binding DeliveryType}" Width="*"/>
                    <DataGridTextColumn Header="Адрес доставки" Binding="{Binding DeliveryAddress}" Width="*"/>
                    <DataGridTextColumn Header="Способ оплаты" Binding="{Binding PaymentType}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Диалог для изменения статуса заказа -->
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="20" Width="320">
                <StackPanel>
                    <TextBlock Text="Изменить статус заказа"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <ComboBox x:Name="DialogStatusComboBox" Margin="0,0,0,10"
                              materialDesign:HintAssist.Hint="Выберите статус">
                        <ComboBoxItem Content="Отправлен"/>
                        <ComboBoxItem Content="Получен"/>
                        <ComboBoxItem Content="Отменен"/>
                    </ComboBox>

                    <TextBox x:Name="DialogCommentTextBox"
                             AcceptsReturn="True"
                             Height="60"
                             materialDesign:HintAssist.Hint="Комментарий"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Отмена"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                Margin="0,0,10,0"/>
                        <Button Content="Сохранить" Click="SaveStatus_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    </materialDesign:DialogHost>
</Page>
